{
  "name": "lalo-app",
  "version": "1.0.0",
  "description": "Production-ready Electron + React + Vite + Tailwind CSS boilerplate with TypeScript support",
  "main": "electron/main.js",
  "type": "module",
  "author": "2nist",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/2nist/electron-react-vite-boilerplate.git"
  },
  "keywords": [
    "electron",
    "react",
    "vite",
    "tailwindcss",
    "typescript",
    "desktop",
    "boilerplate",
    "template"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "verify:sections": "node scripts/verifySections.js",
    "dataset:fetch:salami": "node scripts/datasets/fetchSalami.js",
    "dataset:build:salami-refs": "node scripts/datasets/buildSalamiReferences.js"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.electron.app",
    "productName": "Electron React Vite App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
